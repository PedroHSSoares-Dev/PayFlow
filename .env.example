# ------- PostgreSQL (Container 2) ---------------------------
POSTGRES_USER=payflow
POSTGRES_PASSWORD=payflow@2024
POSTGRES_DB=payflow_db

# ------- Frontend / Vite (build args — Container 1) ---------
# Host do banco visto de dentro da rede Docker
VITE_DB_HOST=db
# Ambiente da aplicação: development | staging | production
VITE_APP_ENV=production
# Título exibido no header da dashboard
VITE_APP_TITLE=PayFlow Dashboard
